# Copy to .env and fill in. Loaded with `set -a; . ./.env; set +a`.
# All hosts/IPs/passwords are deployment-specific — no defaults.

# ── PQ-REACT MCP MariaDB (mcp_hook.py writes here) ────────────────────────
MCP_DB_HOST=<mcp-mariadb-host>           # e.g. mcp.example.local
MCP_DB_PORT=3307
MCP_DB_USER=root
MCP_DB_PASSWORD=                        # required — get from pqreact-mcp-mariadb env
MCP_DB_NAME=PQREACT

# ── QUJATA endpoints (mcp_hook.py POSTs here) ─────────────────────────────
# Newer iperf-shape API on the orchestrator (port 3020). Used by /qujata-api/analyze.
QUJATA_BASE=http://<qujata-api-host>:3020/qujata-api

# Legacy CAM /curl endpoint (port 3010). The default that performance_test.py
# was written against. Point to whatever curl-shaped server you have, or leave
# empty if you don't have one.
QUJATA_LEGACY=http://<qujata-curl-host>:3010/curl

# ── PQ-REACT chat UI (chat_advisor.py POSTs here) ─────────────────────────
CHAT_URL=http://<chat-ui-host>:8081

# ── Tag for CAM-originated rows. Don't change unless you know what you're doing
# — the chat advisor SQL filters on this exact string.
CAM_SOURCE_TAG=cam-context-agility
