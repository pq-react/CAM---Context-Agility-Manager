# Copy to .env and fill in for your CAM host.
# All values have sensible defaults inside docker-compose.yml; this file just
# names the knobs so an operator knows what's tunable.

# Public hostname/IP used in Grafana iframe URLs the browser will fetch.
# When set, the panel emits absolute iframe URLs against this host instead
# of "localhost:3001". Required when accessing the panel from another machine.
CAM_PUBLIC_HOST=10.160.101.76

# CAM's existing InfluxDB (already running at <cam-host>:8086 by the parent
# /opt/cam/docker-compose.yml). The demo panel's Grafana reads from it.
INFLUX_URL=http://host.docker.internal:8086
INFLUX_ORG=pqreact
INFLUX_BUCKET=NUC_metrics
INFLUX_TOKEN=

# Grafana admin password — only matters for the few dashboard tweaks an
# operator wants to make in the UI. Anonymous Viewer is enabled regardless.
GRAFANA_ADMIN_PASSWORD=pqreact-cam-demo

# Optional: when set, the panel can also fan out to the remote QUJATA stack
# instead of the local containers. Kept off by default — this stack IS the
# local backup, the QUJATA stack is the primary.
# QUJATA_API_BASE=http://10.160.101.247:3020/qujata-api
